---
import { SITE, LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url
const subpath = pathname.match(/[^/]+/g)
import Container from "@components/Container.astro"

const isBlogPost = subpath?.[0] === "blog" && subpath?.length > 1;
---

<header id="header" class="fixed top-0 w-full h-16 z-50 bg-white/75 dark:bg-black/75 backdrop-blur-sm border-b border-black/5 dark:border-white/5">
  
  {isBlogPost && (
    <div id="progress-bar" class="absolute bottom-0 left-0 h-[2px] bg-indigo-600 dark:bg-indigo-400 z-[60] w-0 transition-all duration-150"></div>
  )}

  <Container size="md">
    <div class="relative h-16 w-full"> <div class="absolute left-0 top-1/2 -translate-y-1/2 flex gap-1 font-semibold">
        <a href="/" class="flex gap-1 text-current hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
          <svg class="size-6 fill-current">
            <use href="/brand.svg#brand"></use>
          </svg>
          <div class="font-black tracking-tighter">
            {SITE.TITLE}
          </div>
        </a>
      </div>

      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <nav class="hidden md:flex items-center justify-center text-sm gap-1">
          {
            LINKS.map((LINK) => (
              <a href={LINK.HREF} class={cn("h-8 rounded-full px-3 text-current flex items-center justify-center transition-all", pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF ? "bg-black dark:bg-white text-white dark:text-black font-bold" : "hover:bg-black/5 dark:hover:bg-white/20")}>
                {LINK.TEXT}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="buttons absolute right-0 top-1/2 -translate-y-1/2 flex gap-1">
        <a href="/search" class="size-9 rounded-full p-2 flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/20 border border-black/10 dark:border-white/25 transition-all">
          <svg class="size-full stroke-current"><use href="/ui.svg#search"></use></svg>
        </a>
        <button id="header-theme-button" class="size-9 rounded-full p-2 flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/20 border border-black/10 dark:border-white/25 transition-all">
          <svg class="size-full block dark:hidden"><use href="/ui.svg#sun"></use></svg>
          <svg class="size-full hidden dark:block"><use href="/ui.svg#moon"></use></svg>
        </button>
        <button id="header-drawer-button" class="flex md:hidden size-9 rounded-full p-2 items-center justify-center hover:bg-black/5 dark:hover:bg-white/20 border border-black/10 dark:border-white/25">
          <svg id="drawer-open" class="size-full"><use href="/ui.svg#menu"></use></svg>
          <svg id="drawer-close" class="size-full"><use href="/ui.svg#x"></use></svg>
        </button>
      </div>

    </div>
  </Container>
</header>