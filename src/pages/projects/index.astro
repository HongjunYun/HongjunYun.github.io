---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import { PROJECTS } from "@consts";

// 1. 프로젝트 데이터 가져오기
const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 2. 카테고리별 그룹핑
const groupedProjects = projects.reduce((acc, project) => {
  const category = project.data.category || "Others";
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(project);
  return acc;
}, {} as Record<string, typeof projects>);

// 3. 카테고리 정렬 (최신 프로젝트 순)
const sortedCategories = Object.keys(groupedProjects).sort((categoryA, categoryB) => {
  const latestProjectA = groupedProjects[categoryA][0];
  const latestProjectB = groupedProjects[categoryB][0];
  return latestProjectB.data.date.getTime() - latestProjectA.data.date.getTime();
});
---

<PageLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <TopLayout>
    <h1 class="sr-only">Andy Yun - Projects</h1>
    <div class="animate page-heading">
      {PROJECTS.TITLE}
    </div>
  </TopLayout>
  
  <BottomLayout>
    <div class="animate w-full flex flex-col gap-10">
      
      {sortedCategories.map((category) => (
        <section class="flex flex-col gap-4">
          
          {/* 카테고리 제목 */}
          <h2 class="text-xl font-bold border-b border-black/10 dark:border-white/10 pb-2 text-black dark:text-white">
            📂 {category}
          </h2>

          {/* 프로젝트 리스트 */}
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {groupedProjects[category].map((project) => (
              <li>
                <a 
                  href={`/projects/${project.slug}`}
                  class="flex flex-col gap-2 p-4 border border-black/15 dark:border-white/15 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300 h-full group"
                >
                  {/* 제목 */}
                  <div class="font-semibold text-black dark:text-white group-hover:underline">
                    {project.data.title}
                  </div>
                  
                  {/* 요약 */}
                  <div class="text-sm opacity-75 line-clamp-2">
                    {project.data.summary}
                  </div>
                  
                  {/* ✨ 날짜 추가 (mt-auto로 항상 맨 아래 고정) */}
                  <div class="text-xs opacity-50 mt-auto pt-2">
                    {project.data.date.toLocaleDateString('en-US', { 
                      year: 'numeric', 
                      month: 'short', 
                      day: 'numeric' 
                    })}
                  </div>
                </a>
              </li>
            ))}
          </ul>
          
        </section>
      ))}

    </div>
  </BottomLayout>
</PageLayout>