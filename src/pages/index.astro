---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const stack = [
  { 
    text: "Python", 
    icon: "python", 
    href: "https://www.python.org" 
  },
  { 
    text: "PyTorch", 
    icon: "pytorch", 
    href: "https://pytorch.org" 
  },
  { 
    text: "Docker", 
    icon: "docker", 
    href: "https://www.docker.com" 
  },
  {
    text: "C",
    icon: "c",
    href: "https://en.wikipedia.org/wiki/C_(programming_language)"
  },
  {
    text: "C++",
    icon: "cpp",
    href: "https://en.wikipedia.org/wiki/C%2B%2B"
  },
  {
    text: "JAVA",
    icon: "java",
    href: "https://en.wikipedia.org/wiki/Java_(programming_language)"
  },
  {
    text: "Assembly",
    icon: "assembly",
    href: "https://en.wikipedia.org/wiki/Assembly_language"
  },
  {
    text: "mySQL",
    icon: "mysql",
    href: "https://www.mysql.com"
  },
  {
    text: "AWS",
    icon: "aws",
    href: "https://aws.amazon.com"
  },
  {
    text: "mariaDB",
    icon: "mariadb",
    href: "https://mariadb.org"
  },
  {
    text: "VHDL",
    icon: "vhdl",
    href: "https://en.wikipedia.org/wiki/VHDL"
  },
  {
    text: "JavaScript",
    icon: "javascript",
    href: "https://developer.mozilla.org/en-US/docs/Web/JavaScript"
  },
  { 
    text: "Astro", 
    icon: "astro", 
    href: "https://astro.build" 
  },
  {
    text: "Node.js",
    icon: "nodejs",
    href: "https://nodejs.org"
  },
  {
    text: "and more",
    icon: "ellipsis",
    href: "#"
  }
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- Light Mode: Particles -->
  <div class='absolute inset-0 block dark:hidden'>
    <div id='particles1' class='fixed inset-0'></div>
    <div id='particles2' class='fixed inset-0'></div>
    <div id='particles3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class='absolute inset-0 bg-black hidden dark:block'>
    <div id='stars1' class='fixed inset-0'></div>
    <div id='stars2' class='fixed inset-0'></div>
    <div id='stars3' class='fixed inset-0'></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars/>
      <MeteorShower/>
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>
  
  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div id="planetcont" class='animate absolute inset-0 top-1/4 overflow-hidden'>
      <div id="crescent" class='absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-[100vh] aspect-square rounded-full p-[1px] bg-gradient-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%'>
        <div id="planet" class='w-full h-full bg-white dark:bg-black rounded-full p-[1px] overflow-hidden flex justify-center'>
          <div id="blur" class='w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl'/>
        </div>
      </div>
    </div>
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class='relative w-full h-full flex items-center justify-center'>
        <div class='p-5 text-center'>
          <h1 class="sr-only">Andy Yun - UWaterloo Computer Engineering Student</h1>
          <p class='animated text-lg md:text-xl lg:text-2xl font-semibold opacity-75'>
            Hello, I am Andy Yun.
          </p>
          <p class='animated text-2xl md:text-3xl lg:text-4xl font-bold uppercase text-black dark:text-white'>
            UWaterloo Computer Engineering Student
          </p>
          <p class='animated text-sm md:text-base lg:text-lg opacity-75'>
            Currently designing products for humans.
          </p>
          <div id="ctaButtons" class='animated flex flex-wrap gap-4 justify-center mt-5'>
            <a href='/work' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black hover:text-white hover:dark:bg-white hover:dark:text-black transition-colors duration-300 ease-in-out'>
              Where I Worked
            </a>

            <a href='/blog' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black hover:text-white hover:dark:bg-white hover:dark:text-black transition-colors duration-300 ease-in-out'>
              Read my Blog
            </a>

            <a href='/projects' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black hover:text-white hover:dark:bg-white hover:dark:text-black transition-colors duration-300 ease-in-out'>
              View my Projects
            </a>
            
            <a href='/resume' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black hover:text-white hover:dark:bg-white hover:dark:text-black transition-colors duration-300 ease-in-out'>
              View my Resume
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article class="space-y-4 text-justify">
          <p>
            I am a <b>Computer Engineering student</b> at the <b>University of Waterloo</b> (completed 3A term). Currently, I am fulfilling my mandatory military service in the <b>Republic of Korea Armed Forces</b>.
          </p>
          
          <p>
            <b>Professional Journey: From FinTech to 6G</b>
          </p>
          <p>
            My engineering path is defined by diverse technical challenges. Most recently, I worked as a <b>Student Intern at Korea Fund Ratings</b>, leveraging <b>Python and Machine Learning</b> for financial data validation. Prior to that, I built scalable backend systems at <b>Escape Platforms Inc.</b> using <b>AWS (Lambda, DynamoDB)</b> and Node.js.
          </p>
          <p>
            My research capability was honed at <b>Huawei Ottawa R&D Centre</b> as a <b>6G Researcher</b>, where I simulated next-gen networks using C++ and Python. I also gained industrial software experience at <b>Stackpole International</b> (automotive manufacturing) and started my journey at <b>The Hacksmith</b>, contributing to creative engineering projects with C++ and Node.js.
          </p>

          <p>
            <b>Current Focus: The Barracks R&D</b>
          </p>
          <p>
            Even while serving in the military, my passion for engineering remains active. During my off-duty hours, I am developing an <b>AI-powered market analysis engine</b>. This personal project allows me to synthesize my experience in <b>financial data (Korea Fund Ratings)</b> and <b>backend architecture (Escape Platforms)</b> to build a sophisticated system using <b>Python and PyTorch</b>.
          </p>

          <p>
            Whether I'm optimizing a 6G simulation or architecting a cloud backend, I am driven by the same goal: <b>to build robust systems that solve real problems.</b>
          </p>
        </article>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Recent posts
            </p>
            <a href="/blog" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All posts
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            Still Stack
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard 
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <div>
            <p class="text-sm text-black/75 dark:text-white/75">
              These are the technologies I have experience with and continue to use in my projects.
            </p>
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Recent projects
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All projects
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            Let's Connect
          </p>
          <p>
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>
</PageLayout>
