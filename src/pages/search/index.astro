---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import Search from "@components/Search";
import { SEARCH } from "@consts";
import { formatDate } from "@lib/utils";

// 1. 데이터 가져오기
const posts = (await getCollection("blog")).filter((post) => !post.data.draft);
const projects = (await getCollection("projects")).filter((post) => !post.data.draft);
const work = await getCollection("work");

// 2. 검색 엔진용 데이터 통합 변환
const allData = [
  ...posts.map(post => ({
    collection: "blog",
    slug: post.slug,
    body: post.body,
    data: {
      title: post.data.title,
      // 🚨 post.data.description -> post.data.summary로 수정
      description: post.data.summary, 
      summary: post.data.summary,
      date: post.data.date,
      tags: post.data.tags || []
    }
  })),
  ...projects.map(project => ({
    collection: "projects",
    slug: project.slug,
    body: project.body,
    data: {
      title: project.data.title,
      // 🚨 project.data.description -> project.data.summary로 수정
      description: project.data.summary,
      summary: project.data.summary,
      date: project.data.date,
      tags: project.data.tags || []
    }
  })),
  ...work.map(entry => {
    const dateEndString = entry.data.dateEnd
      ? entry.data.dateEnd instanceof Date
        ? formatDate(entry.data.dateEnd)
        : entry.data.dateEnd
      : "Present";

    const stack = entry.data.stack ? [...entry.data.stack] : [];
    const stackString = stack.join(" ");

    return {
      collection: "work",
      slug: entry.slug || "",
      body: `${entry.body} ${stackString}`,
      data: {
        title: `${entry.data.company} - ${entry.data.role}`,
        description: `Work Experience (${formatDate(entry.data.dateStart)} - ${dateEndString})`,
        summary: `Work Experience (${formatDate(entry.data.dateStart)} - ${dateEndString})`,
        date: entry.data.dateStart,
        tags: stack
      }
    };
  })
];
---

<PageLayout title={SEARCH.TITLE} description={SEARCH.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      {SEARCH.TITLE}
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <Search client:load data={allData} />
    </div>
  </BottomLayout>
</PageLayout>